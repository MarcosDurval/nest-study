{
  "uid": "customers-observability",
  "title": "Customers Observability",
  "tags": ["customers", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "Customer Creation Total",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(customers_customer_creation_total[5m]))",
          "legendFormat": "creations"
        }
      ]
    },
    {
      "id": 2,
      "title": "Customer Creation Success Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(customers_customer_creation_total{outcome=\"success\"}[5m])) / clamp_min(sum(rate(customers_customer_creation_total[5m])), 1)",
          "legendFormat": "success rate"
        }
      ]
    },
    {
      "id": 3,
      "title": "Customer Creation Failures by Reason",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (rate(customers_customer_creation_total{outcome=\"failure\"}[5m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Customer Creation Duration p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, outcome) (rate(customers_customer_creation_duration_seconds_bucket[5m])))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Outbox Publications",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (outcome, reason) (rate(customers_outbox_publication_total[5m]))",
          "legendFormat": "{{outcome}} {{reason}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Outbox Events by Status",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 11 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (customers_outbox_events)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Oldest Pending Outbox Age",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "customers_outbox_oldest_pending_age_seconds",
          "legendFormat": "age"
        }
      ]
    },
    {
      "id": 8,
      "title": "Welcome Email Delivery Total",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(customers_welcome_email_delivery_total[5m]))",
          "legendFormat": "deliveries"
        }
      ]
    },
    {
      "id": 9,
      "title": "Welcome Email Failures by Reason",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 18 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (rate(customers_welcome_email_delivery_total{outcome=\"failure\"}[5m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Welcome Email Retries and DLQ",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 18 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (rate(customers_welcome_email_retry_total[5m]))",
          "legendFormat": "retry {{reason}}"
        },
        {
          "refId": "B",
          "expr": "sum by (reason) (rate(customers_welcome_email_dlq_total[5m]))",
          "legendFormat": "dlq {{reason}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Welcome Email Delivery Duration p95",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 25 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, outcome) (rate(customers_welcome_email_delivery_duration_seconds_bucket[5m])))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "RabbitMQ Queue Depth",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 25 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (rabbitmq_queue_messages_ready{queue=~\"email.customer-created|email.customer-created.retry|email.customer-created.dlq\"})",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "RabbitMQ Consumers",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (rabbitmq_queue_consumers{queue=~\"email.customer-created|email.customer-created.retry|email.customer-created.dlq\"})",
          "legendFormat": "{{queue}}"
        }
      ]
    }
  ]
}
